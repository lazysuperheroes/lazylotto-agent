{
  "name": "conservative",
  "version": "1.0.0",
  "description": "Low risk. Targets high win rate pools only (10%+). Small batches, tight budget, generous reserve. Suitable for cautious users or smaller balances.",
  "poolFilter": {
    "type": "all",
    "minWinRate": 10,
    "feeToken": "any",
    "minPrizeCount": 1
  },
  "budget": {
    "maxSpendPerSession": 50,
    "maxSpendPerPool": 20,
    "maxEntriesPerPool": 3,
    "reserveBalance": 20,
    "currency": "HBAR"
  },
  "playStyle": {
    "action": "buy_and_roll",
    "entriesPerBatch": 1,
    "minExpectedValue": -5,
    "claimImmediately": true,
    "transferToOwner": true
  },
  "schedule": {
    "enabled": false,
    "cron": "0 */8 * * *",
    "maxSessionsPerDay": 3
  }
}
