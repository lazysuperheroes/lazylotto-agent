{
  "name": "conservative",
  "version": "0.2",
  "description": "Low risk. Targets high win rate pools only (10%+). Small batches, tight budget, generous reserve. Suitable for cautious users or smaller balances.",
  "poolFilter": {
    "type": "all",
    "minWinRate": 10,
    "feeToken": "any",
    "minPrizeCount": 1
  },
  "budget": {
    "tokenBudgets": {
      "hbar": { "maxPerSession": 25, "maxPerPool": 10, "reserve": 20 },
      "0.0.8011209": { "maxPerSession": 100, "maxPerPool": 40, "reserve": 30 }
    },
    "maxEntriesPerPool": 3
  },
  "playStyle": {
    "action": "buy_and_roll",
    "entriesPerBatch": 1,
    "minExpectedValue": -5,
    "transferToOwner": true,
    "preferNftPrizes": false
  },
  "schedule": {
    "enabled": false,
    "cron": "0 */8 * * *",
    "maxSessionsPerDay": 3
  }
}
