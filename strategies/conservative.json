{
  "name": "conservative",
  "version": "1.0.0",
  "description": "High win rate pools, small entries, low budget — minimizes losses",
  "poolFilter": {
    "type": "all",
    "minWinRate": 10,
    "feeToken": "any",
    "minPrizeCount": 1
  },
  "budget": {
    "maxSpendPerSession": 20,
    "maxSpendPerPool": 10,
    "maxEntriesPerPool": 3,
    "reserveBalance": 10,
    "currency": "LAZY"
  },
  "playStyle": {
    "action": "buy_and_roll",
    "entriesPerBatch": 1,
    "minExpectedValue": -5,
    "claimImmediately": true,
    "transferToOwner": true
  },
  "schedule": {
    "enabled": false,
    "cron": "0 */8 * * *",
    "maxSessionsPerDay": 3
  }
}
