{
  "name": "balanced",
  "version": "1.0.0",
  "description": "Moderate risk. Plays all pool types with a reasonable EV threshold. Good default for most users and deposit sizes.",
  "poolFilter": {
    "type": "all",
    "feeToken": "any",
    "minPrizeCount": 1
  },
  "budget": {
    "maxSpendPerSession": 100,
    "maxSpendPerPool": 40,
    "maxEntriesPerPool": 5,
    "reserveBalance": 10,
    "currency": "HBAR"
  },
  "playStyle": {
    "action": "buy_and_roll",
    "entriesPerBatch": 2,
    "minExpectedValue": -20,
    "claimImmediately": true,
    "transferToOwner": true
  },
  "schedule": {
    "enabled": false,
    "cron": "0 */6 * * *",
    "maxSessionsPerDay": 4
  }
}
