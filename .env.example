# Hedera Network
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=302e...

# LazyLotto MCP Endpoint
LAZYLOTTO_MCP_URL=https://dapp.lazysuperheroes.com/api/mcp
LAZYLOTTO_MCP_API_KEY=ll_xxxxx

# LazyLotto Contract Addresses (testnet)
LAZYLOTTO_CONTRACT_ID=0.0.8463358
LAZYLOTTO_STORAGE_ID=0.0.8463338
LAZYLOTTO_POOL_MANAGER_ID=0.0.8463369
LAZY_GAS_STATION_ID=0.0.8011801
# LAZY token ID (testnet: 0.0.8011209, mainnet: 0.0.1311037)
LAZY_TOKEN_ID=0.0.8011209

# Owner wallet — receives prizes and withdrawals
OWNER_EOA=0.0.XXXXXX

# Strategy (conservative | balanced | aggressive | path to custom JSON)
STRATEGY=balanced

# Delegate Registry (optional — for --audit win rate boost checks)
DELEGATE_REGISTRY_ID=0.0.XXXXXX
# Comma-separated LSH collection token IDs to check for delegation
LSH_TOKEN_IDS=0.0.XXXXXX,0.0.YYYYYY

# Multi-User Custodial Mode (optional)
MULTI_USER_ENABLED=false
RAKE_DEFAULT_PERCENT=5.0
RAKE_MIN_PERCENT=2.0
RAKE_MAX_PERCENT=5.0
DEPOSIT_POLL_INTERVAL_MS=10000
MAX_USER_BALANCE=10000
HCS20_TOPIC_ID=
HCS20_TICK=LLCRED

# MCP Server Authentication (recommended for production)
MCP_AUTH_TOKEN=

# Restrict operator fee withdrawals to this address (optional)
OPERATOR_WITHDRAW_ADDRESS=

# Per-user daily withdrawal velocity cap (HBAR equivalent, default 1000)
# Bounds blast radius if a user session is compromised.
WITHDRAWAL_DAILY_CAP_HBAR=1000

# SaucerSwap Price API (mainnet only)
SAUCERSWAP_API_KEY=

# HOL Registry (optional)
HOL_API_KEY=

# ── Hosted (Vercel) Mode ──────────────────────────────────────────
# Required when running as the multi-user hosted agent on Vercel.

# Comma-separated allow list of origins permitted to call the API.
# REQUIRED in production — wildcard '*' is rejected.
# Example: AUTH_PAGE_ORIGIN=https://testnet-agent.lazysuperheroes.com
AUTH_PAGE_ORIGIN=

# Comma-separated Hedera account IDs that get the 'admin' tier on auth.
# Omit to disable admin tier entirely. These accounts can run reconcile,
# refund, view all users, and access the admin dashboard.
ADMIN_ACCOUNTS=

# Upstash Redis — required for sessions and ledger persistence on Vercel.
# Vercel auto-injects these when you connect a Vercel-managed Upstash DB.
# Local dev: leave both unset to use the in-memory fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Or use the Upstash-native names (either pair works):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public agent base URL (used by the discover endpoint and verify route)
NEXT_PUBLIC_APP_URL=https://testnet-agent.lazysuperheroes.com

# Override the MCP endpoint URL returned by /api/auth/verify
# (defaults to ${NEXT_PUBLIC_APP_URL}/api/mcp).
AGENT_MCP_URL=

# Override the Verification Directus collection name (default: 'Verification')
VERIFICATION_TABLE=
